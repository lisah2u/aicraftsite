---
interface Props {
  title: string;
  date: Date;
  summary: string;
  tags: string[];
  href: string;
}

const { title, date, summary, tags, href } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="knowledge-card">
  <div class="knowledge-card__meta">
    <time datetime={date.toISOString().slice(0, 10)} class="knowledge-card__date">
      {formattedDate}
    </time>
    {tags.length > 0 && (
      <span class="knowledge-card__tag">{tags[0]}</span>
    )}
  </div>
  <h3 class="knowledge-card__title">
    <a href={href}>{title}</a>
  </h3>
  <p class="knowledge-card__summary">{summary}</p>
  <a href={href} class="knowledge-card__link" aria-label={`Read: ${title}`}>
    Read
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M5 12h14M12 5l7 7-7 7"/>
    </svg>
  </a>
</article>

<style>
  .knowledge-card {
    padding: 1.75rem 2rem 2rem;
    background: rgba(255, 255, 255, 0.5);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition:
      background var(--duration-fast) var(--ease-standard),
      box-shadow var(--duration-fast) var(--ease-standard),
      transform var(--duration-fast) var(--ease-standard);
  }

  .knowledge-card:hover {
    background: rgba(255, 255, 255, 0.85);
    box-shadow: 0 4px 24px rgba(23, 23, 23, 0.07);
    transform: translateY(-2px);
  }

  .knowledge-card__meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .knowledge-card__date {
    font-size: 0.8125rem;
    color: var(--color-ink-soft);
    font-weight: 500;
  }

  .knowledge-card__tag {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-ink-soft);
    background: rgba(23, 23, 23, 0.07);
    padding: 0.2rem 0.6rem;
    border-radius: 100px;
    letter-spacing: 0.03em;
  }

  .knowledge-card__title {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -0.02em;
    color: var(--color-ink);
  }

  .knowledge-card__title a {
    color: inherit;
    text-decoration: none;
    opacity: 1 !important;
    transition: opacity var(--duration-fast) var(--ease-standard);
  }

  .knowledge-card__title a:hover {
    opacity: 0.72 !important;
  }

  .knowledge-card__summary {
    margin: 0;
    font-size: 0.9375rem;
    color: var(--color-ink-soft);
    line-height: 1.65;
    flex: 1;
  }

  .knowledge-card__link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-ink);
    text-decoration: none;
    margin-top: 0.25rem;
    opacity: 1 !important;
    transition: gap var(--duration-fast) var(--ease-standard);
  }

  .knowledge-card__link:hover {
    gap: 0.625rem;
    opacity: 1 !important;
  }
</style>
