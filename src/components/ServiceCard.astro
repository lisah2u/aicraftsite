---
interface Props {
  number: string;
  title: string;
  description: string;
  tags?: string[];
  href?: string;
}

const { number, title, description, tags, href } = Astro.props;
---

<article class="service-card">
  <div class="service-card__header">
    <span class="service-card__number">{number}</span>
    {href && (
      <a href={href} class="service-card__arrow" aria-label={`View ${title} services`}>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M7 17L17 7M17 7H7M17 7v10"/>
        </svg>
      </a>
    )}
  </div>
  <h3 class="service-card__title">
    {href ? <a href={href}>{title}</a> : title}
  </h3>
  <p class="service-card__description">{description}</p>
  {tags && tags.length > 0 && (
    <ul class="service-card__tags" aria-label="Includes">
      {tags.map(tag => <li>{tag}</li>)}
    </ul>
  )}
</article>

<style>
  .service-card {
    padding: 2rem 2rem 2.25rem;
    background: rgba(255, 255, 255, 0.5);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition:
      background var(--duration-fast) var(--ease-standard),
      box-shadow var(--duration-fast) var(--ease-standard),
      transform var(--duration-fast) var(--ease-standard);
  }

  .service-card:hover {
    background: rgba(255, 255, 255, 0.85);
    box-shadow: 0 4px 24px rgba(23, 23, 23, 0.07);
    transform: translateY(-2px);
  }

  .service-card__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  .service-card__number {
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--color-ink-soft);
  }

  .service-card__arrow {
    color: var(--color-ink-soft);
    transition: color var(--duration-fast) var(--ease-standard), transform var(--duration-fast) var(--ease-standard);
    display: flex;
    opacity: 1 !important;
  }

  .service-card:hover .service-card__arrow {
    color: var(--color-ink);
    transform: translate(2px, -2px);
  }

  .service-card__title {
    margin: 0;
    font-size: 1.3rem;
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.025em;
    color: var(--color-ink);
  }

  .service-card__title a {
    color: inherit;
    text-decoration: none;
    opacity: 1 !important;
  }

  .service-card__description {
    margin: 0;
    font-size: 0.9375rem;
    color: var(--color-ink-soft);
    line-height: 1.65;
    flex: 1;
  }

  .service-card__tags {
    margin: 0.5rem 0 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .service-card__tags li {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-ink-soft);
    background: rgba(23, 23, 23, 0.06);
    padding: 0.25rem 0.625rem;
    border-radius: 100px;
    white-space: nowrap;
  }
</style>
