---
import Layout from '../layouts/Layout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import KnowledgeCard from '../components/KnowledgeCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('knowledge', ({ data }) => !data.draft);
const recentPosts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const services = [
  {
    number: '01',
    title: 'Data & AI Strategy',
    description:
      "Frame the right problem before touching code. I help you identify what you actually need—whether that's a searchable archive, an AI assistant, or a cleaner dataset—and sketch the smallest useful solution.",
    tags: ['Information architecture', 'AI agent design', 'Problem framing'],
    href: '/services#strategy',
  },
  {
    number: '02',
    title: 'Dashboards & Decision Tools',
    description:
      'Design of  dashboards built around actual questions so answers are at your fingertips.',
    tags: ['Data visualization', 'Grants & programs', 'Visual reporting'],
    href: '/services#dashboards',
  },
  {
    number: '03',
    title: 'Automation & Data Engineering',
    description:
      'Reduce copy-paste and disarticulated data. Supported with AI-driven automation with human-validated control gates so you save time without losing oversight.',
    tags: ['Workflow automation', 'Data cleanup', 'Integrations'],
    href: '/services#automation',
  },
  {
    number: '04',
    title: 'Connected Web Presence',
    description:
      'Your website as a live data application and not a static brochure. Forms that write to your systems, user search that answers real questions, and AI-enhanced features grounded in your own content.',
    tags: ['Modern Web Frameworks', 'Semantic search', 'Content architecture'],
    href: '/services#web',
  },
];
---

<Layout
  title="AiCraft — AI-Powered Data Solutions for Small Organizations"
  description="AiCraft builds intelligence-grade AI, data, and web tools for small businesses, nonprofits, and local government teams. One to two clients at a time, clear scopes, plain language."
>
  <!-- Hero -->
  <section class="hero-section">
    <div class="container hero-inner">
      <div class="hero-text">
        <h1 class="sr-only">Data & AI solutions for small organizations — AiCraft</h1>
        <p class="eyebrow">Data & AI consultancy</p>
        <p class="hero-subtitle">
          I help small businesses, local governments, and nonprofits create workflows that turn messy, underused data into websites with clear dashboards, automations, and decision tools that fit your organization's needs.
        </p>
        <div class="hero-actions">
          <a href="/contact" class="button button--primary">Talk about your idea</a>
          <a href="/services" class="button button--secondary">Explore services</a>
        </div>
        <p class="hero-subtext">A short call to see what's possible with your existing data.</p>
      </div>

      <div class="hero-canvas-wrap" aria-hidden="true">
        <canvas id="hero-canvas"></canvas>
      </div>
    </div>
  </section>

  <!-- Proof strip -->
  <section class="proof-strip">
    <div class="container proof-strip__inner">
      <div class="proof-item">
        <strong class="proof-item__strong">25+ years in AI & data</strong>
        <span class="proof-item__clarifier">From enterprise intelligence to small nonprofits</span>
      </div>
      <div class="proof-item">
        <strong class="proof-item__strong">Federal-grade AI systems</strong>
        <span class="proof-item__clarifier">Enterprise knowledge retrieval & language AI</span>
      </div>
      <div class="proof-item">
        <strong class="proof-item__strong">2-3 clients per quarter</strong>
        <span class="proof-item__clarifier">Focused engagement</span>
      </div>
      <div class="proof-item">
        <strong class="proof-item__strong">You own everything</strong>
        <span class="proof-item__clarifier">Code, data, documentation—all yours</span>
      </div>
    </div>
  </section>

  <!-- Who this is for -->
  <section class="section audience-section">
    <div class="container">
      <div class="audience-inner reveal">
        <p class="eyebrow">Who this is for</p>
        <h2 class="audience-heading">
          Built for small organizations that can't hire a full data department
        </h2>
        <p class="audience-body">
          If your operations live in spreadsheets, inboxes, and a simple website—but modern data,
          AI, and automation feel out of reach—you're exactly who I work with. I build lightweight tools that plug into your existing systems so you get real leverage without big platforms or long contracts.
        </p>
      </div>
    </div>
  </section>

  <!-- Services grid -->
  <section class="section services-section" id="services">
    <div class="container">
      <div class="section-heading-block reveal">
        <p class="eyebrow">Services</p>
        <h2 class="services-heading">From un-ordered data to clear decisions</h2>
        <p class="services-subheading">
          Together, we start small: one workflow, one report, or one decision that's painful today.
          Then we design and build around it—using modern tooling, but explained in plain language.
        </p>
      </div>
      <div class="service-grid">
        {services.map((service, i) => (
          <div class={`reveal reveal--delay-${i}${i === 0 ? ' service-grid__featured' : ''}`}>
            <ServiceCard {...service} />
          </div>
        ))}
      </div>
      <div class="services-link reveal">
        <a href="/services" class="button button--secondary">See full service details →</a>
      </div>
    </div>
  </section>

  <!-- How we work -->
  <section class="section process-section">
    <div class="container process-inner">
      <div class="process-text reveal">
        <p class="eyebrow">How we work together</p>
        <h2 class="process-heading">A focused partner, not a big agency</h2>
        <p class="process-body">
          You get senior-level data science, information design, and AI expertise—but delivered
          like a small studio: depth over volume, clear scopes, and straightforward
          communication. No layers, no mystery.
        </p>
        <a href="/about" class="process-more">Learn more about me →</a>
      </div>
      <ol class="process-steps">
        <li class="process-step reveal">
          <span class="step-num">01</span>
          <div>
            <strong>Listen</strong>
            <p>I clarify your goals, constraints, and current tools—before suggesting anything.</p>
          </div>
        </li>
        <li class="process-step reveal">
          <span class="step-num">02</span>
          <div>
            <strong>Design</strong>
            <p>I sketch the smallest useful solution and walk you through it before we build.</p>
          </div>
        </li>
        <li class="process-step reveal">
          <span class="step-num">03</span>
          <div>
            <strong>Build & refine</strong>
            <p>I implement, ship quickly, then iterate based on real use—not assumptions.</p>
          </div>
        </li>
      </ol>
    </div>
  </section>

  <!-- Knowledge preview -->
  {recentPosts.length > 0 && (
    <section class="section knowledge-section">
      <div class="container">
        <div class="knowledge-header reveal">
          <div>
            <p class="eyebrow">Knowledge</p>
            <h2 class="knowledge-heading">Distilled insights</h2>
          </div>
          <a href="/knowledge" class="button button--secondary knowledge-all-link">All articles →</a>
        </div>
        <div class="knowledge-grid">
          {recentPosts.map((post, i) => (
            <div class={`reveal reveal--delay-${i}`}>
              <KnowledgeCard
                title={post.data.title}
                date={post.data.date}
                summary={post.data.summary}
                tags={post.data.tags}
                href={`/knowledge/${post.slug}`}
              />
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA band -->
  <section class="cta-band section">
    <div class="container cta-band__inner reveal">
      <div>
        <p class="eyebrow">Let's talk</p>
        <h2 class="cta-band__heading">Ready to put your data to work?</h2>
        <p class="cta-band__body">
          Share a bit about your team and the decisions you're trying to improve, and I'll
          propose a small, concrete project we can deliver in weeks—not months.
        </p>
      </div>
      <a href="/contact" class="button button--primary cta-band__btn">Start a project</a>
    </div>
  </section>
</Layout>

<script>
  // ── Ring / triangle canvas animation ─────────────────────────────────────
  // Three separate equilateral triangles, each spinning around its own center.
  // The three centers drift lazily as a group. Lines fade in — order from chaos.
  const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement | null;
  if (canvas && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const ctx = canvas.getContext('2d')!;

    let W = 0, H = 0;
    const CYCLE_MS = 12000; // ms per full fade-in / fade-out cycle

    // Individual spin speeds (rad/ms) — slightly different for organic drift
    const SPIN_SPEEDS  = [0.000100, 0.000107, 0.000093];
    const GROUP_SPEED  = 0.000018;
    const CENTER_FRAC  = 0.26;
    const TRI_FRAC     = 0.15;
    const BREATHE_AMP  = 0.028;
    const BREATHE_FREQ = 0.00035;

    // Mouse attraction spring physics
    const ATTRACT_R = 90;   // px — influence radius
    const ATTRACT_F = 1.6;  // peak force toward mouse
    const SPRING_K  = 0.07; // pull back to natural position
    const DAMP      = 0.76; // velocity decay per frame
    const MAX_DISP  = 52;   // px cap on displacement

    interface PtOffset { dx: number; dy: number; vx: number; vy: number; }
    const ptOffsets: PtOffset[] = Array.from({ length: 9 }, () =>
      ({ dx: 0, dy: 0, vx: 0, vy: 0 })
    );
    let mouseX = -9999, mouseY = -9999;

    function resize() {
      const dpr  = window.devicePixelRatio || 1;
      const rect = (canvas.parentElement as HTMLElement).getBoundingClientRect();
      W = rect.width;
      H = rect.height;
      canvas.width  = W * dpr;
      canvas.height = H * dpr;
      canvas.style.width  = W + 'px';
      canvas.style.height = H + 'px';
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }

    function triPoints(tri: number, ts: number): [number, number][] {
      const S = Math.min(W, H);
      const groupAngle = GROUP_SPEED * ts + Math.PI / 2;
      const cAngle = groupAngle + tri * (2 * Math.PI / 3);
      const Rc = S * CENTER_FRAC;
      const cx = W / 2 + Rc * Math.cos(cAngle);
      const cy = H / 2 + Rc * Math.sin(cAngle);
      const Rt      = S * TRI_FRAC;
      const breathe = Rt * BREATHE_AMP * Math.sin(BREATHE_FREQ * ts + tri * (2 * Math.PI / 3));
      const r       = Rt + breathe;
      const rot     = SPIN_SPEEDS[tri] * ts;
      return [0, 1, 2].map(j => {
        const a = rot + j * (2 * Math.PI / 3);
        return [cx + r * Math.cos(a), cy + r * Math.sin(a)] as [number, number];
      });
    }

    function draw(ts: number) {
      const raw = (1 - Math.cos((ts / CYCLE_MS) * Math.PI * 2)) / 2;
      const lineOpacity = raw * raw * (3 - 2 * raw) * 0.9;

      ctx.clearRect(0, 0, W, H);
      const circleR = Math.min(W, H) * 0.050;
      const lineW   = Math.max(2, circleR * 0.42);

      const allNatural = [0, 1, 2].map(tri => triPoints(tri, ts));

      // Apply spring physics to each point and compute displaced render positions
      const allPts: [number, number][][] = allNatural.map((pts, tri) =>
        pts.map(([nx, ny], j) => {
          const off = ptOffsets[tri * 3 + j];
          const rx = nx + off.dx, ry = ny + off.dy;
          // Attraction toward mouse from current displaced position
          const toMX = mouseX - rx, toMY = mouseY - ry;
          const dist = Math.hypot(toMX, toMY);
          if (dist < ATTRACT_R && dist > 0) {
            const strength = ATTRACT_F * (1 - dist / ATTRACT_R);
            off.vx += (toMX / dist) * strength;
            off.vy += (toMY / dist) * strength;
          }
          // Spring back toward natural position, then damp
          off.vx = (off.vx - SPRING_K * off.dx) * DAMP;
          off.vy = (off.vy - SPRING_K * off.dy) * DAMP;
          off.dx = Math.max(-MAX_DISP, Math.min(MAX_DISP, off.dx + off.vx));
          off.dy = Math.max(-MAX_DISP, Math.min(MAX_DISP, off.dy + off.vy));
          return [nx + off.dx, ny + off.dy] as [number, number];
        })
      );

      // Lines first — circles paint over the endpoints
      for (let tri = 0; tri < 3; tri++) {
        const pts = allPts[tri];
        ctx.beginPath();
        ctx.moveTo(pts[0][0], pts[0][1]);
        ctx.lineTo(pts[1][0], pts[1][1]);
        ctx.lineTo(pts[2][0], pts[2][1]);
        ctx.closePath();
        ctx.strokeStyle = `rgba(23, 23, 23, ${(lineOpacity * 0.9).toFixed(3)})`;
        ctx.lineWidth   = lineW;
        ctx.stroke();
      }

      // Solid circles on top — always visible, mask line endpoints
      for (let tri = 0; tri < 3; tri++) {
        for (const [x, y] of allPts[tri]) {
          ctx.beginPath();
          ctx.arc(x, y, circleR, 0, Math.PI * 2);
          ctx.fillStyle = '#171717';
          ctx.fill();
        }
      }
    }

    let started = false;
    function loop(ts: number) {
      draw(ts);
      requestAnimationFrame(loop);
    }

    canvas.addEventListener('mousemove', e => {
      const r = canvas.getBoundingClientRect();
      mouseX = e.clientX - r.left;
      mouseY = e.clientY - r.top;
    });
    canvas.addEventListener('mouseleave', () => { mouseX = -9999; mouseY = -9999; });

    const ro = new ResizeObserver(() => {
      resize();
      if (!started) {
        started = true;
        requestAnimationFrame(loop);
      }
    });
    ro.observe(canvas.parentElement as Element);
  }

  // ── Scroll reveal ──────────────────────────────────────────────────────────
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
  );

  document.querySelectorAll('.reveal').forEach((el) => {
    const delay = el.classList.contains('reveal--delay-1') ? 80
      : el.classList.contains('reveal--delay-2') ? 160
      : el.classList.contains('reveal--delay-3') ? 240
      : 0;
    (el as HTMLElement).style.transitionDelay = `${delay}ms`;
    observer.observe(el);
  });
</script>

<style>
  /* ── Screen-reader only ── */
  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border: 0;
  }

  /* ── Hero ── */
  .hero-section {
    padding-block: clamp(56px, 10vw, 120px);
    border-bottom: 1px solid var(--color-border);
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 3.5rem;
    align-items: center;
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0;
  }

  /* Eyebrow as an accent badge */
  .hero-text .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.75rem;
    padding: 0.3rem 0.75rem;
    background: rgba(217, 170, 82, 0.12);
    border: 1px solid rgba(217, 170, 82, 0.35);
    border-radius: 100px;
    font-size: 0.8125rem;
    color: var(--color-ink);
    letter-spacing: 0.05em;
  }

  .hero-subtitle {
    margin: 0 0 2.25rem;
    font-family: var(--font-display);
    font-size: clamp(1.35rem, 2.4vw, 1.75rem);
    font-weight: 500;
    color: var(--color-ink);
    line-height: 1.45;
    letter-spacing: -0.02em;
    max-width: 26ch;
  }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 1.25rem;
  }

  .hero-subtext {
    margin: 0;
    font-size: 0.875rem;
    color: var(--color-ink-soft);
    line-height: 1.5;
  }

  /* ── Canvas ── */
  .hero-canvas-wrap {
    position: relative;
    aspect-ratio: 1;
    width: 100%;
    max-width: 380px;
    justify-self: center;
    cursor: crosshair;
  }

  #hero-canvas {
    display: block;
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  /* ── Proof strip ── */
  .proof-strip {
    border-bottom: 1px solid var(--color-border);
    padding-block: 2.5rem;
    background: rgba(255, 255, 255, 0.4);
  }

  .proof-strip__inner {
    display: flex;
    gap: 2.5rem;
    flex-wrap: wrap;
  }

  .proof-item {
    border-left: 2px solid var(--color-accent);
    padding-left: 1rem;
    flex: 1 1 160px;
  }

  .proof-item__strong {
    display: block;
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--color-ink);
    font-family: var(--font-display);
    line-height: 1.3;
    letter-spacing: -0.01em;
  }

  .proof-item__clarifier {
    display: block;
    font-size: 0.8125rem;
    color: var(--color-ink-soft);
    margin-top: 0.2rem;
    line-height: 1.4;
  }

  /* ── Audience section ── */
  .audience-inner {
    max-width: 680px;
  }

  .audience-heading {
    margin: 0 0 1.25rem;
    font-size: clamp(1.4rem, 2.8vw, 2rem);
    color: var(--color-ink);
    line-height: 1.15;
  }

  .audience-body {
    margin: 0;
    font-size: 1.0625rem;
    color: var(--color-ink-soft);
    line-height: 1.7;
  }

  /* ── Services section ── */
  .services-section {
    background: rgba(255, 255, 255, 0.55);
  }

  .section-heading-block {
    max-width: 640px;
    margin-bottom: 3rem;
  }

  .services-heading {
    margin: 0 0 1rem;
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    color: var(--color-ink);
    line-height: 1.08;
  }

  .services-subheading {
    margin: 0;
    font-size: 1.0625rem;
    color: var(--color-ink-soft);
    line-height: 1.7;
  }

  .service-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  .service-grid__featured {
    grid-column: 1 / -1;
  }

  .service-grid__featured :global(.service-card) {
    border-left: 3px solid var(--color-accent);
    padding: 2.25rem 2.5rem 2.5rem;
  }

  .service-grid__featured :global(.service-card__title) {
    font-size: 1.5rem;
  }

  .service-grid__featured :global(.service-card__description) {
    max-width: 64ch;
  }

  .services-link {
    margin-top: 2rem;
  }

  /* ── Process section ── */
  .process-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .process-heading {
    margin: 0 0 1rem;
    font-size: clamp(1.4rem, 2.8vw, 2rem);
    color: var(--color-ink);
    line-height: 1.15;
  }

  .process-body {
    margin: 0 0 1.5rem;
    font-size: 1.0625rem;
    color: var(--color-ink-soft);
    line-height: 1.7;
  }

  .process-more {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-ink);
    text-decoration: none;
    opacity: 1 !important;
    transition: opacity var(--duration-fast) var(--ease-standard);
  }

  .process-more:hover { opacity: 0.65 !important; }

  .process-steps {
    margin: 0; padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
  }

  .process-step {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .process-step:first-child { border-top: 1px solid var(--color-border); }

  .step-num {
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--color-ink-soft);
    flex-shrink: 0;
    padding-top: 2px;
    min-width: 1.75rem;
  }

  .process-step strong {
    display: block;
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-ink);
    margin-bottom: 0.25rem;
    font-family: var(--font-display);
  }

  .process-step p {
    margin: 0;
    font-size: 0.9375rem;
    color: var(--color-ink-soft);
    line-height: 1.6;
  }

  /* ── Knowledge section ── */
  .knowledge-section {
    background: rgba(255, 255, 255, 0.55);
  }

  .knowledge-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 2.5rem;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .knowledge-heading {
    margin: 0;
    font-size: clamp(1.4rem, 2.8vw, 2rem);
    color: var(--color-ink);
    line-height: 1.15;
  }

  .knowledge-all-link { flex-shrink: 0; }

  .knowledge-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  /* ── CTA band ── */
  .cta-band {
    background: var(--color-panel-dark);
    color: #ffffff;
  }

  .cta-band .eyebrow { color: rgba(255, 255, 255, 0.55); }

  .cta-band__inner {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .cta-band__heading {
    margin: 0 0 0.75rem;
    font-size: clamp(1.75rem, 4vw, 3rem);
    line-height: 1.1;
    color: #ffffff;
    max-width: 18ch;
  }

  .cta-band__body {
    margin: 0;
    font-size: 1.0625rem;
    color: rgba(255, 255, 255, 0.65);
    max-width: 42ch;
    line-height: 1.65;
  }

  .cta-band__btn {
    background: var(--color-accent);
    color: var(--color-panel-dark);
    flex-shrink: 0;
    align-self: center;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .knowledge-grid    { grid-template-columns: repeat(2, 1fr); }
    .process-inner     { grid-template-columns: 1fr; gap: 2.5rem; }
  }

  @media (max-width: 720px) {
    .hero-inner {
      grid-template-columns: 1fr;
    }
    .hero-canvas-wrap {
      order: -1; /* canvas above text on mobile */
      max-width: 280px;
      margin: 0 auto;
    }
    .canvas-hint { bottom: -1.5rem; }
  }

  @media (max-width: 640px) {
    .service-grid      { grid-template-columns: 1fr; }
    .knowledge-grid    { grid-template-columns: 1fr; }
    .knowledge-header  { flex-direction: column; align-items: flex-start; }
    .cta-band__inner   { flex-direction: column; align-items: flex-start; }
    .proof-strip__inner { gap: 1.5rem; }
    .proof-item        { flex: 1 1 calc(50% - 1.5rem); }
  }
</style>
